<UserControl x:Class="LedgerLensMaking.UserControls.BankPaymentsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="940">
    <UserControl.Resources>
        <!-- Define styles within UserControl.Resources -->
        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#821131"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Crimson"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                   BorderBrush="{TemplateBinding BorderBrush}"
                   BorderThickness="{TemplateBinding BorderThickness}"
                   CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2205B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CustomButtonStyle2" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#38D200"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Crimson"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B0F780"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#821131"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FABC3F"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C7253E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#2787ED"/>  <!-- Original Value #2787ED -->
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="1" Background="Transparent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SimpleComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row for Title -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Bank Cash Account and ComboBox -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Current Balance -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Labels -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Input Fields -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Label under GLAccount -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Extra Input Field for Nattation -->
            <RowDefinition Height="Auto"/>
            <!-- Empty Row 2 -->
            <RowDefinition Height="*"/>
            <!-- Row for Data Grid -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="20"/>
        </Grid.ColumnDefinitions>
        <!-- Centered Title -->
        <TextBlock Text="{Binding IndividualName}" Grid.Row="0" Grid.ColumnSpan="7" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="AliceBlue"  />

        <!-- Bank Cash Account Label and ComboBox -->
        <TextBlock Text="Bank / Cash Account" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontSize="24" VerticalAlignment="Center" Foreground="AliceBlue" Margin="10,20"/>
        <ComboBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Width="240"   Margin="10,20" VerticalAlignment="Center"
                  FontSize="18"
                  HorizontalAlignment="Left"
                  ItemsSource="{Binding BankAccounts}"
                  DisplayMemberPath="Account" 
                  SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                  Style="{StaticResource SimpleComboBoxStyle}">
            <ComboBox.Resources>
                <!-- Set the background of the popup that contains the items -->
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1A3C7A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1A3C7A"/>
            </ComboBox.Resources>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#1A3C7A"/>
                    <Setter Property="Foreground" Value="AliceBlue"/>
                    <Setter Property="FontSize" Value="18"/>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>

        <!-- Current Balance Label and TextBox -->
        <TextBlock Text="Current Balance" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" FontSize="24" VerticalAlignment="Center" Foreground="AliceBlue" Margin="10,0"/>

        <Border Grid.Row="2"
                Grid.Column="2"
                Grid.ColumnSpan="2"
                Width="240"
                Height="40"
                HorizontalAlignment="Left"
                Margin="10,0,10,0"
                BorderBrush="AliceBlue"
                BorderThickness="2"
                Background="#9B4444"
                VerticalAlignment="Center">
            <TextBlock Text="{Binding CurrentBalance, StringFormat={}{0:N2}}"
                       Foreground="White"
                       FontSize="20"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Padding="5,0" />
        </Border>


        <!-- Labels for Date, Reference, Account, and Amount -->
        <TextBlock Text="Date" Grid.Row="3"  Grid.Column="0"  VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"  />
        <TextBlock Text="Reference" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"   />
        <TextBlock Text="Account" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Amount" Grid.Row="3" Grid.Column="4" Grid.ColumnSpan="2" VerticalAlignment="Center"  Foreground="AliceBlue" FontSize="18" Margin="-90,10"/>

        <!-- Input Fields for Date, Reference, Account, and Amount -->
        <TextBox Grid.Row="4" Grid.Column="0" Width="120" Height="40" Margin="10,0" FontSize="20" VerticalAlignment="Center" 
                 Text="{Binding DateInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="DateTextBox_LostFocus"  
                 GotFocus="TextBox_GotFocus"
                 PreviewKeyDown="OnPreviewKeyDown" 
                 x:Name="DateInput"
                 />

        <TextBox Grid.Row="4" Grid.Column="1" Width="120" Height="40" Margin="10,0" FontSize="20" VerticalAlignment="Center"
         Text="{Binding RefInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         LostFocus="RefTextBox_LostFocus" GotFocus="TextBox_GotFocus" 
         PreviewKeyDown="OnPreviewKeyDown"  
         x:Name="RefTextBox"
                 />

        <ComboBox Grid.Row="4" Grid.Column="2" Width="291" Margin="10,0" FontSize="20" VerticalAlignment="Center"
                  ItemsSource="{Binding GLAccounts}"
                  DisplayMemberPath="Account"
                  SelectedItem="{Binding SelectedGLAccount, Mode=TwoWay}"
                  Style="{StaticResource SimpleComboBoxStyle}"/>

        <ComboBox Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="3" HorizontalAlignment="Left"   Width="240" Margin="10,0" FontSize="20" VerticalAlignment="Center"
                  ItemsSource="{Binding GLAccounts}"
                  DisplayMemberPath="Account"
                  SelectedItem="{Binding SelectedGLAccount, Mode=TwoWay}"
                  Style="{StaticResource SimpleComboBoxStyle}"/>
        
            <TextBox  HorizontalAlignment="Left" Grid.Row="4" Grid.Column="4" Margin="-90"  Width="140" Height="40"  
              FontSize="20" HorizontalContentAlignment="Left" 
              VerticalAlignment="Center" 
              Text="{Binding AmountInput, UpdateSourceTrigger=PropertyChanged}"
              GotFocus="TextBox_GotFocus" LostFocus="AmountTextBox_LostFocus"  />
            <TextBlock Text="{Binding AmountMessage}"
                       Margin="-120,0"
                       Grid.Row="4"   
                       Grid.Column="5"
                       TextAlignment="Left"
                       HorizontalAlignment="Left"
                       FontSize="18"
                       Foreground="AliceBlue"/>
        
        <TextBlock Text="" Grid.Row="4" Grid.Column="4"  Width="100" Margin="10,0" VerticalAlignment="Center"/>
        <!-- If you want to have a box for displaying units -->
        
            
       

        
        <!-- Have it in the 5th Row -->
        <!-- Label under GLAccount ComboBox -->
        <!--  textblock definition    Grid.Row="5" Grid.Column="2" Text="Extra Row to Display the Results of DialogBox" FontSize="16" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0" / -->




        <!-- Empty rows for future use -->
        <TextBlock Text="Narration" Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBox Grid.Row="7" Grid.Column="2" Grid.ColumnSpan="2" Width="240" Height="40" Margin="10,0" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center"
                 Text="{Binding NarrationInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="NarrationTextBox_LostFocus"/>
        <StackPanel Orientation="Horizontal" Grid.Row="7" Grid.Column="4">
            <Button  Command="{Binding SavePaymentCommand}" Margin="-90,10" HorizontalAlignment="Left" Content="Payment" Style="{StaticResource CustomButtonStyle}" Width="80"  />
            <Button   Content="SF" Style="{StaticResource CustomButtonStyle2}"   Margin="10,0" HorizontalAlignment="Left"  VerticalAlignment="Center"
      Command="{Binding SfCommand}" IsEnabled="{Binding IsSfEnabled}" 
      />

        </StackPanel>


        <!-- DataGrid -->
        <DataGrid Grid.Row="8" Grid.ColumnSpan="7"
     Width="900"
     ItemsSource="{Binding BankEntryGridData}"
     AutoGenerateColumns="False"
     IsEnabled="{Binding IsGridEnabled}"
     SelectionMode="Single"
     Margin="0,10"
     FontSize="16"
     FontFamily="Consolas"
     Background="Transparent"
     Foreground="Black"
     BorderThickness="0"
     HorizontalGridLinesBrush="White"
     VerticalGridLinesBrush="White"
     RowBackground="#B4C6E7"
     CanUserAddRows="False"
     AlternatingRowBackground="#D9E2F3"
     ScrollViewer.VerticalScrollBarVisibility="Disabled"
     SelectedItem="{Binding SelectedBankEntryGridModel}">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#20306B"/>
                    <Setter Property="Foreground" Value="AliceBlue"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="BorderBrush" Value="White"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding TDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="110"/>

                <DataGridTemplateColumn Header="Ref" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ref}">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Unix:" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Unix}"/>
                                            <TextBlock Text="Narration:" FontWeight="Bold" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding Narration}"/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                       </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>


                </DataGridTemplateColumn>


                <DataGridTextColumn Header="Particulars" Binding="{Binding Particulars}" Width="280"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Balance" Binding="{Binding RunningBalance, StringFormat={}{0:N2}}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Actions" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center">
                                <!-- Delete Button -->
                                <Button Content="D"
        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
        CommandParameter="{Binding}"
        Width="40"
        Height="22"
        Style="{StaticResource SmallButtonStyle}" 
        VerticalAlignment="Center"                                       
    />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
