<UserControl x:Class="LedgerLensMaking.UserControls.BankReceiptsSubledgerUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Define styles within UserControl.Resources -->
        <Style x:Key="CustomButtonStyle2" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#2787ED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="CadetBlue"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="MediumPurple"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#38D200"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="YellowGreen"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B0F780"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="1" Background="Transparent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SimpleComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row for Title Row.0 -->
            <RowDefinition Height="Auto"/>
            <!-- For Label and Command Button Add New Row.1 -->
            <RowDefinition Height="*"/>
            <!-- Row for DataGrid (takes remaining space) Row.3 -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Buttons Row.4 -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Text="Subledger Account Selection" Grid.Row="0" Grid.Column="0" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="AliceBlue" />

        <!-- Add New Button Section -->
        <StackPanel Grid.Row="1" Margin="0,10" Orientation="Horizontal">
            <Border Width="278" Height="40" Margin="10,0,10,0" BorderBrush="AliceBlue" BorderThickness="2" Background="#1A3C7A" VerticalAlignment="Center">
                <TextBlock Text="{Binding GlAccountName}" Foreground="White" FontSize="20" VerticalAlignment="Center" Padding="5,0" />
            </Border>
            <Button Command="{Binding AddNew}" Content="Add New" Style="{StaticResource CustomButtonStyle}" Width="100" Margin="0"/>
        </StackPanel>

        <!-- DataGrid Section -->
        <DataGrid Grid.Row="2" Grid.Column="0" Margin="0,10,0,0"
              ItemsSource="{Binding QrySubledgerFDBalances}"
              SelectedItem="{Binding SelectedFD, Mode=TwoWay}"
              AutoGenerateColumns="False"
              IsEnabled="{Binding IsGridEnabled}"
              SelectionMode="Single"
              FontSize="16"
              FontFamily="Consolas"
              Background="Transparent"
              Foreground="Black"
              BorderThickness="0"
              HorizontalGridLinesBrush="White"
              VerticalGridLinesBrush="White"
              RowBackground="#B4C6E7"
              CanUserAddRows="False"
              AlternatingRowBackground="#D9E2F3"
              MaxHeight="300"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
              ScrollViewer.CanContentScroll="True"
              >

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#20306B"/>
                    <Setter Property="Foreground" Value="AliceBlue"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="BorderBrush" Value="White"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Particulars" Binding="{Binding Subaccount}" Width="338"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding TotalFD, StringFormat={}{0:N2}}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Close Button (Always Visible) -->
        <Button Grid.Row="3" Command="{Binding CloseFdCommand}" Content="Close" 
            Style="{StaticResource CustomButtonStyle2}" Width="100" Margin="0,15"/>
    </Grid>



</UserControl>