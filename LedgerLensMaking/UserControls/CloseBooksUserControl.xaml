<UserControl x:Class="LedgerLensMaking.UserControls.CloseBooksUserControl"
                         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="750">
    <UserControl.Resources>
        <!-- Define styles within UserControl.Resources -->
        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#821131"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Crimson"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2205B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CreditButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="Teal"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="OliveDrab"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B0F780"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DebitButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#821131"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Crimson"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2205B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomButtonStyle2" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#38D200"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Crimson"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B0F780"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#38D200"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="YellowGreen"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B0F780"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <!-- Original Value #2787ED -->
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="1" Background="Transparent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SimpleComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row0 for Title -->
            <RowDefinition Height="Auto"/>
            <!-- Row1 Period -->
            <RowDefinition Height="Auto"/>
            <!-- Row2 Current Date -->
            <RowDefinition Height="Auto"/>
            <!-- Row3 for Labels -->
            <RowDefinition Height="Auto"/>
            <!-- Row4 for Input Fields -->
            <RowDefinition Height="Auto"/>
            <!-- Row5 Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Row6 for Extra Input Field for Nattation -->
            <RowDefinition Height="*"/>
            <!-- Row7 for Data Grid 11 is Auto Height!!! -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="310"/>
            <!-- Increase the width slightly for more space -->
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Centered Title -->
        <TextBlock Text="{Binding IndividualName}" Grid.Row="0" Grid.ColumnSpan="5" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Firebrick"  />
        <TextBlock Text="{Binding PeriodLine}" Grid.Row="1" Grid.ColumnSpan="5" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Firebrick"  />
        <TextBlock Text="{Binding PrintDate}" Grid.Row="2" Grid.ColumnSpan="5" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Firebrick"  />
        <TextBlock Text="{Binding ClosingMessage}" Grid.Row="3" Grid.ColumnSpan="5" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Silver"  />

        <TextBlock Text="" Grid.Row="4"  Grid.Column="0"  VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Message 1" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Message 2" Grid.Row="4" Grid.Column="3" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="" Grid.Row="4" Grid.Column="4" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>

        <!-- Password Input-->

        <PasswordBox Grid.Row="5" Grid.Column="1" Width="120" Height="40" Margin="10,0" FontSize="20" VerticalAlignment="Center"
             PasswordChanged="Password1Changed" />

        <PasswordBox Grid.Row="5" Grid.Column="3" Width="100" Height="40" Margin="10,0" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center"
             PasswordChanged="Password2Changed" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="6" Grid.Column="2">
            <Button Command="{Binding CloseCommand}" IsEnabled="{Binding IsCloseEnabled}"  Content="Close" Style="{StaticResource DebitButtonStyle}" Width="100" Margin="0"/>
            <Button Command="{Binding CancelCommand}" Content="Cancel" Style="{StaticResource CreditButtonStyle}" Width="100" Margin="20"/>
        </StackPanel>






    </Grid>
</UserControl>