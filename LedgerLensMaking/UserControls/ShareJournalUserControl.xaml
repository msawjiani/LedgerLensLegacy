<UserControl x:Class="LedgerLensMaking.UserControls.ShareJournalUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="750">
    <UserControl.Resources>
        <!-- Define styles within UserControl.Resources -->
        <Style x:Key="CustomButtonStyle2" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#38D200"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Crimson"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B0F780"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#38D200"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="YellowGreen"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B0F780"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <!-- Original Value #2787ED -->
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="1" Background="Transparent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SimpleComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row for Title -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Debit Account Label and Combo -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Credit Account Label and Combo -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Labels -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Input Fields -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Label under GLAccount -->
            <RowDefinition Height="Auto"/>
            <!-- Row for Extra Input Field for Nattation -->
            <RowDefinition Height="Auto"/>
            <!-- Empty Row 2 -->
            <RowDefinition Height="Auto"/>
            <!-- Empty Row 8 -->
            <RowDefinition Height="Auto"/>
            <!-- Empty Row 9 -->            
            <RowDefinition Height="*"/>
            <!-- Row for Data Grid -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="310"/>
            <!-- Increase the width slightly for more space -->
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Centered Title -->
        <TextBlock Text="{Binding IndividualName}" Grid.Row="0" Grid.ColumnSpan="5" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="AliceBlue"  />

        <!-- Bank Cash Account Label and ComboBox -->
        <TextBlock Text="Credit Account (GL)" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontSize="24" VerticalAlignment="Center" Foreground="AliceBlue" Margin="10,20"/>
        <ComboBox Grid.Row="1" Grid.Column="2" Width="283" Margin="10,20" VerticalAlignment="Center"
                  FontSize="18"
                  ItemsSource="{Binding CreditAccounts}"
                  DisplayMemberPath="Account" 
                  SelectedItem="{Binding SelectedCreditAccount, Mode=TwoWay}"
                  Style="{StaticResource SimpleComboBoxStyle}">
            <ComboBox.Resources>
                <!-- Set the background of the popup that contains the items -->
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1A3C7A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1A3C7A"/>
            </ComboBox.Resources>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#1A3C7A"/>
                    <Setter Property="Foreground" Value="AliceBlue"/>
                    <Setter Property="FontSize" Value="18"/>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>

        <!-- Current Balance Label and TextBox -->
        <TextBlock Text="Shares Account (GL)" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" FontSize="24" VerticalAlignment="Center" Foreground="AliceBlue" Margin="10,0"/>
        <ComboBox Grid.Row="2" Grid.Column="2" Width="283" Margin="10" VerticalAlignment="Center"
                  FontSize="18"
                  ItemsSource="{Binding DebitAccounts}"
                  DisplayMemberPath="Account" 
                  SelectedItem="{Binding SelectedDebitAccount, Mode=TwoWay}"
                  Style="{StaticResource SimpleComboBoxStyle}">
            <ComboBox.Resources>
                <!-- Set the background of the popup that contains the items -->
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1A3C7A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1A3C7A"/>
            </ComboBox.Resources>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#1A3C7A"/>
                    <Setter Property="Foreground" Value="AliceBlue"/>
                    <Setter Property="FontSize" Value="18"/>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>

        <!-- Labels for Date, Reference, Account, and Amount -->
        <TextBlock Text="Date" Grid.Row="3"  Grid.Column="0"  VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Reference" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Narration" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        

        <!-- Input Fields for Date, Reference, Account, and Amount -->
        <TextBox Grid.Row="4" Grid.Column="0" Width="120" Height="40" Margin="10,0" FontSize="20" VerticalAlignment="Center" 
                 Text="{Binding DateInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="GenericTextBox_LostFocus"
                 GotFocus="TextBox_GotFocus"/>

        <TextBox Grid.Row="4" Grid.Column="1" Width="120" Height="40" Margin="10,0" FontSize="20" VerticalAlignment="Center"
                 Text="{Binding RefInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="GenericTextBox_LostFocus"
                 GotFocus="TextBox_GotFocus"/>

        <TextBox Grid.Row="4" Grid.Column="2" Width="320" Height="40" Margin="10,0" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center"
                 Text="{Binding NarrationInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="GenericTextBox_LostFocus"
                 GotFocus="TextBox_GotFocus"/>

        
        <TextBlock Text="" Grid.Row="4" Grid.Column="4"  Width="100" Margin="10,0" VerticalAlignment="Center"/>
        <!-- Label under GLAccount ComboBox -->
        <!--  textblock definition    Grid.Row="5" Grid.Column="2" Text="Extra Row to Display the Results of DialogBox" FontSize="16" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0" / -->
        <TextBlock Text="Purchase Date" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" 
                   Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Qty" Grid.Row="5"  Grid.Column="1"  VerticalAlignment="Center" 
                   Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Purchase Rate" Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        
        

        <!-- Empty rows for future use -->
        <TextBox Grid.Row="6" Grid.Column="0" Width="130" Height="40" Margin="10,0" FontSize="20" HorizontalContentAlignment="Left" 
         VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding PurchaseDateInput, UpdateSourceTrigger=PropertyChanged}"
                 GotFocus="TextBox_GotFocus"
                 LostFocus="GenericTextBox_LostFocus"/>

        <TextBox Grid.Row="6" Grid.Column="1" Width="120" Height="40" Margin="10,0" FontSize="20" VerticalAlignment="Center" 
         Text="{Binding PurchaseQtyInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         GotFocus="TextBox_GotFocus"
         LostFocus="GenericTextBox_LostFocus"
          
                 />

        <TextBox Grid.Row="6" Grid.Column="2" HorizontalAlignment="Left" Width="120" Height="40" Margin="10,0" FontSize="20" VerticalAlignment="Center"
         Text="{Binding PurchaseRateInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         GotFocus="TextBox_GotFocus"
         LostFocus="GenericTextBox_LostFocus"
                 />

        <Grid Grid.Row="6" Grid.Column="2"  HorizontalAlignment="Right" Margin="10"  VerticalAlignment="Center">
            <Button Command="{Binding SavePaymentCommand}" Content="Journalize" Style="{StaticResource CustomButtonStyle}" Width="100" Margin="0"/>
        </Grid>


        <!-- DataGrid -->
        <DataGrid Grid.Row="10" Grid.ColumnSpan="5"
                  Width="530"
          ItemsSource="{Binding SharesCharts}"
          AutoGenerateColumns="False"
          IsEnabled="{Binding IsGridEnabled}"
          SelectionMode="Single"
          FontSize="16"
          FontFamily="Consolas"
          Margin="0,10"
          Background="Transparent"
          Foreground="Black"
          BorderThickness="0"
          HorizontalGridLinesBrush="White"
          VerticalGridLinesBrush="White"
          RowBackground="#B4C6E7"
          CanUserAddRows="False"
          AlternatingRowBackground="#D9E2F3"
          ScrollViewer.VerticalScrollBarVisibility="Disabled"
          SelectedItem="{Binding SelectedShare}">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#20306B"/>
                    <Setter Property="Foreground" Value="AliceBlue"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="BorderBrush" Value="White"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ShareId}" Width="100"/>

                <DataGridTextColumn Header="Company" Binding="{Binding Company}" Width="422"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
