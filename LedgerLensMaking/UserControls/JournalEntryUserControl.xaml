<UserControl x:Class="LedgerLensMaking.UserControls.JournalEntryUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="750">
    <UserControl.Resources>
        
            <!-- Define styles within UserControl.Resources -->
            <Style x:Key="SmallButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="30"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Background" Value="#821131"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="Crimson"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Change appearance when the button is disabled -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="#A0A0A0"/>
                        <Setter Property="Foreground" Value="FloralWhite"/>
                        <Setter Property="BorderBrush" Value="AliceBlue"/>
                    </Trigger>
                    <!-- Change appearance on mouse hover -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F2205B"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="CreditButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="30"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Background" Value="Teal"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="OliveDrab"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Change appearance when the button is disabled -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="#A0A0A0"/>
                        <Setter Property="Foreground" Value="FloralWhite"/>
                        <Setter Property="BorderBrush" Value="AliceBlue"/>
                    </Trigger>
                    <!-- Change appearance on mouse hover -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#B0F780"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="DebitButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="30"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Background" Value="#821131"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="Crimson"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Change appearance when the button is disabled -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="#A0A0A0"/>
                        <Setter Property="Foreground" Value="FloralWhite"/>
                        <Setter Property="BorderBrush" Value="AliceBlue"/>
                    </Trigger>
                    <!-- Change appearance on mouse hover -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F2205B"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CustomButtonStyle2" TargetType="Button">
                <Setter Property="Width" Value="30"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Background" Value="#38D200"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="Crimson"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Change appearance when the button is disabled -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="#A0A0A0"/>
                        <Setter Property="Foreground" Value="FloralWhite"/>
                        <Setter Property="BorderBrush" Value="AliceBlue"/>
                    </Trigger>
                    <!-- Change appearance on mouse hover -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#B0F780"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="CustomButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="80"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="Background" Value="#38D200"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="YellowGreen"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!-- Change appearance when the button is disabled -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="#A0A0A0"/>
                        <Setter Property="Foreground" Value="FloralWhite"/>
                        <Setter Property="BorderBrush" Value="AliceBlue"/>
                    </Trigger>
                    <!-- Change appearance on mouse hover -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#B0F780"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
                <Setter Property="BorderBrush" Value="#2787ED"/>
                <!-- Original Value #2787ED -->
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="1" Background="Transparent" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SimpleComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="BorderBrush" Value="#2787ED"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Height" Value="40"/>
            </Style>
        </UserControl.Resources>


        <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0  -->
            <RowDefinition Height="Auto"/>
            <!-- 1  -->
            <RowDefinition Height="Auto"/>
            <!-- 2  -->
            <RowDefinition Height="Auto"/>
            <!-- 3  -->
            <RowDefinition Height="Auto"/>
            <!-- 4  -->
            <RowDefinition Height="Auto"/>
            <!-- 5  -->
            <RowDefinition Height="Auto"/>
            <!-- 6  -->
            <RowDefinition Height="Auto"/>
            <!-- 7  -->
            <RowDefinition Height="Auto"/>
            <!-- 8  -->
            <RowDefinition Height="Auto"/>
            <!-- 9  -->
            <RowDefinition Height="Auto"/>
            <!-- 10 -->
            <RowDefinition Height="*"/>
            <!-- 11 : DataGrid fills/scrolls -->
            <RowDefinition Height="Auto"/>
            <!-- 12 : Totals BELOW grid -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Text="{Binding IndividualName}" Grid.Row="0" Grid.ColumnSpan="5"
                   FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="AliceBlue"/>

        <!-- Labels -->
        <TextBlock Text="Date"      Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Reference" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Account"   Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>
        <TextBlock Text="Amount"    Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Foreground="AliceBlue" FontSize="18" Margin="10,10"/>

        <!-- Inputs -->
        <TextBox Grid.Row="2" Grid.Column="0" Width="120" Height="40" Margin="10,0" FontSize="20"
                 Text="{Binding DateInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBox Grid.Row="2" Grid.Column="1" Width="120" Height="40" Margin="10,0" FontSize="20"
                 Text="{Binding RefInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <ComboBox Grid.Row="2" Grid.Column="2" Width="283" Margin="10,20" VerticalAlignment="Center"
                  FontSize="18"
                  ItemsSource="{Binding AvailableAccounts}"
                  DisplayMemberPath="Account"
                  SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                  Style="{StaticResource SimpleComboBoxStyle}">
            <ComboBox.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"    Color="#1A3C7A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1A3C7A"/>
            </ComboBox.Resources>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#1A3C7A"/>
                    <Setter Property="Foreground" Value="AliceBlue"/>
                    <Setter Property="FontSize"   Value="18"/>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>

        <TextBox Grid.Row="2" Grid.Column="3" Width="100" Height="40" Margin="10,0" FontSize="20" HorizontalAlignment="Left"
                 Text="{Binding AmountInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBox Grid.Row="3" Grid.Column="2" Width="280" Height="40" Margin="10,0" FontSize="20"
                 Text="{Binding NarrationInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Buttons -->
        <Grid Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left"   Margin="10" VerticalAlignment="Center">
            <Button Command="{Binding DebitCommand}"  Content="Debit"     Style="{StaticResource DebitButtonStyle}"  Width="100"/>
        </Grid>
        <Grid Grid.Row="4" Grid.Column="2" HorizontalAlignment="Center" Margin="10" VerticalAlignment="Center">
            <Button Command="{Binding SaveCommand}"   Content="Journalize" Style="{StaticResource CustomButtonStyle}" Width="100"/>
        </Grid>
        <Grid Grid.Row="4" Grid.Column="3" HorizontalAlignment="Left"   Margin="10" VerticalAlignment="Center">
            <Button Command="{Binding CreditCommand}" Content="Credit"    Style="{StaticResource CreditButtonStyle}" Width="100"/>
        </Grid>

        <!-- DataGrid in star row -->
        <DataGrid Grid.Row="11" Grid.ColumnSpan="5"
                  ItemsSource="{Binding JournalEntries}"
                  AutoGenerateColumns="False"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.CanContentScroll="True"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  Width="720"
                  IsEnabled="{Binding IsGridEnabled}"
                  SelectionMode="Single"
                  FontSize="16"
                  FontFamily="Consolas"
                  Margin="0,10"
                  Background="Transparent"
                  Foreground="Black"
                  BorderThickness="0"
                  HorizontalGridLinesBrush="White"
                  VerticalGridLinesBrush="White"
                  RowBackground="#B4C6E7"
                  CanUserAddRows="False"
                  AlternatingRowBackground="#D9E2F3"
                  SelectedItem="{Binding SelectedJournalEntry}">
            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment"   Value="Center"/>
                    <Setter Property="Foreground"                 Value="Black"/>
                    <Setter Property="FontFamily"                 Value="Consolas"/>
                </Style>
                <Style x:Key="NumericCellStyle" TargetType="DataGridCell">
                    <Setter Property="HorizontalContentAlignment" Value="Right"/>
                    <Setter Property="VerticalContentAlignment"   Value="Center"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Account" Binding="{Binding Account}" Width="290">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Debit" Binding="{Binding DebitColumn, StringFormat={}{0:N2}}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Credit" Binding="{Binding CreditColumn, StringFormat={}{0:N2}}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Balance" Binding="{Binding BalanceAfter, StringFormat={}{0:N2}}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Actions" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Content="D"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Width="40" Height="22"
                                        Style="{StaticResource SmallButtonStyle}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Totals BELOW the grid -->
        <Grid Grid.Row="12" Grid.ColumnSpan="5" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="1" Text="{Binding TotalDebits,  StringFormat={}{0:N2}}"
                       FontWeight="Bold" HorizontalAlignment="Right" Foreground="AliceBlue" FontSize="16"/>
            <TextBlock Grid.Column="2" Text="{Binding TotalCredits, StringFormat={}{0:N2}}"
                       FontWeight="Bold" HorizontalAlignment="Right" Foreground="AliceBlue" FontSize="16"/>
            <TextBlock Grid.Column="0" Text="Difference"
                       FontWeight="Bold" HorizontalAlignment="Right" Foreground="AliceBlue" FontSize="16"/>
            <TextBlock Grid.Column="3" Text="{Binding DifferenceBalance, StringFormat={}{0:N2}}"
                       FontWeight="Bold" HorizontalAlignment="Right" Foreground="AliceBlue" FontSize="16"/>
        </Grid>

    </Grid>
</UserControl>
