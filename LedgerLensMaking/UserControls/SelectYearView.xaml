<UserControl x:Class="LedgerLensMaking.UserControls.SelectYearView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#2D486B"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent" Margin="10" HorizontalAlignment="Center" VerticalAlignment="Top">
        <StackPanel Width="600" Background="Transparent">
            <Border Background="Transparent" Margin="5" CornerRadius="10" BorderBrush="Transparent" BorderThickness="0">
                <Border.Effect>
                    <DropShadowEffect Color="Transparent" Direction="320" ShadowDepth="5" Opacity="0.5" BlurRadius="10"/>
                </Border.Effect>
                <TextBlock Text="{Binding IndividualName}" 
                           FontSize="26" 
                           Foreground="#D3D3D3"
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,20"/>
            </Border>

            <DataGrid x:Name="MyYearsDataGrid" 
                      ItemsSource="{Binding AccountingYears}" 
                      SelectedItem="{Binding SelectedYear, Mode=TwoWay}"
                      AutoGenerateColumns="False"  
                      Width="400"
                      SelectionMode="Single"
                      FontSize="16"
                      Background="Transparent"
                      Foreground="Black"
                      BorderThickness="0"
                      HorizontalGridLinesBrush="White"
                      VerticalGridLinesBrush="White"
                      RowBackground="#B4C6E7"
                      CanUserAddRows="False"
                      AlternatingRowBackground="#D9E2F3"
                      >
                <DataGrid.Resources>
                    <!-- Selection background & text just for this grid -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#365E9D"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#365E9D"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding YearId}" Header="Year Id" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="10,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding StartDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="140" Header="From">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="10,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding EndDate, StringFormat={}{0:dd-MMM-yyyy}}" Width="*" Header="To">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="10,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Close Button -->
            <Button Content="Close" Width="150" HorizontalAlignment="Center" Margin="0,20,0,0" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
