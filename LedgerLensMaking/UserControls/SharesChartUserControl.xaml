<UserControl x:Class="LedgerLensMaking.UserControls.SharesChartUserControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="450" Width="900">
    <UserControl.Resources>
        <!-- Define styles within UserControl.Resources -->
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#20306B"/>
            <Setter Property="Foreground" Value="AliceBlue"/>
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                 BorderBrush="{TemplateBinding BorderBrush}"
                 BorderThickness="{TemplateBinding BorderThickness}"
                 CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Change appearance when the button is disabled -->
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0A0A0"/>
                    <Setter Property="Foreground" Value="FloralWhite"/>
                    <Setter Property="BorderBrush" Value="AliceBlue"/>
                </Trigger>
                <!-- Change appearance on mouse hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#38D200"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="1" Background="Transparent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SimpleComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#2787ED"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Title with Margin -->
        <TextBlock Text="{Binding IndividualName}" 
                   FontSize="24" FontWeight="Bold" 
                   Grid.Row="0" Grid.Column="0" 
                   Grid.ColumnSpan="2" HorizontalAlignment="Center" 
                   VerticalAlignment="Center" Foreground="White"
                   Margin="0,10,0,10"/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3" Grid.Column="0"
          ItemsSource="{Binding SharesCharts}"
          AutoGenerateColumns="False"
          IsEnabled="{Binding IsGridEnabled}"
          SelectionMode="Single"
          FontSize="16"
          Background="Transparent"
          Foreground="Black"
          BorderThickness="0"
          HorizontalGridLinesBrush="White"
          VerticalGridLinesBrush="White"
          RowBackground="#B4C6E7"
          CanUserAddRows="False"
          AlternatingRowBackground="#D9E2F3"
          MaxHeight="319"
          Margin="0,-35,0,20"  
          ScrollViewer.VerticalScrollBarVisibility="Disabled"
          SelectedItem="{Binding SelectedCompany}">

            <!-- Define the style for the DataGridColumnHeader -->
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#20306B"/>
                    <Setter Property="Foreground" Value="AliceBlue"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>

                <!-- Define the style for DataGridCell -->
                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Company" Binding="{Binding Company}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>


        <!-- StackPanel with input fields -->
        <StackPanel Grid.Row="2" Grid.Column="1" Margin="10">
            <Grid HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="Ledger Account" FontSize="16" FontWeight="Bold"
                       Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,5" Foreground="White"/>
                <ComboBox Width="350" Height="40"
                      VerticalContentAlignment="Center"
                      Grid.Row="1" Grid.Column="0"
                      Margin="0,0,0,10"
                      ItemsSource="{Binding GLAccounts}"
                      DisplayMemberPath="Account"   
                      SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                Style="{StaticResource SimpleComboBoxStyle}"/>


                    <Label Content="Company Name" FontSize="16" FontWeight="Bold"
                       Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                       Margin="0,0,0,5" Foreground="White"/>
                <TextBox Width="350" Height="40"
                     VerticalContentAlignment="Center"
                     Grid.Row="3" Grid.Column="0"
                     Margin="0,0,0,10"
                     Text="{Binding CompanyName, Mode=TwoWay}"
                     Style="{StaticResource CustomTextBoxStyle}"/>


            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
                <Button Content="Add" Style="{StaticResource CustomButtonStyle}"
                        Command="{Binding AddCommand}" IsEnabled="{Binding IsAddEnabled}"/>
                <Button Content="Modify" Style="{StaticResource CustomButtonStyle}" Command="{Binding ModifyCommand}" IsEnabled="{Binding IsModifyEnabled}"/>
                <Button Content="Save" Style="{StaticResource CustomButtonStyle}"
                        Command="{Binding SaveCommand}" IsEnabled="{Binding IsSaveEnabled}"/>
                <Button Content="Cancel" Style="{StaticResource CustomButtonStyle}"
                        Command="{Binding CancelCommand}" IsEnabled="{Binding IsCancelEnabled}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
