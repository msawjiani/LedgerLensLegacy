<Window x:Class="LedgerLensMaking.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LedgerLensMaking"
        mc:Ignorable="d"
        Icon="Assets/Logo1.png"
        Title="Ledger Lens" Height="800" Width="1000" WindowState="Maximized">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#020024" Offset="0"/>
            <GradientStop Color="#090979" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel with 3D effect and border -->
        <Border Grid.Column="0" Background="Transparent" Margin="5" CornerRadius="10" BorderBrush="#808080" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#C8D6C5" Direction="320" ShadowDepth="5" Opacity="0.5" BlurRadius="10"/>
            </Border.Effect>
            <StackPanel Background="Transparent">
                <Image Source="{Binding PhotoFile}" Height="100" Width="200" Margin="0 30 0 0"/>
                <TreeView Name="SidebarMenu" Background="Transparent" BorderThickness="0" FontFamily="Myriad" FontSize="22" Margin="0 40 0 0">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Foreground" Value="#D3D3D3"/>
                            <Setter Property="HeaderTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#D3D3D3" FontFamily="Myriad" FontSize="22">
                                        </TextBlock>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.Resources>
                    <TreeViewItem Header="Individual Information">
                        <TreeViewItem Header="Select Individual" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Close Books" Selected="MenuItem_Selected" />
                    </TreeViewItem>
                    <TreeViewItem Header="Account Information">
                        <TreeViewItem Header="Ledger Accounts" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Companies" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Subledger" Selected="MenuItem_Selected" />
                    </TreeViewItem>
                    <TreeViewItem Header="Voucher Entry">
                        <TreeViewItem Header="Receipts" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Payments" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Journal" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Share Purchase" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Share Sales" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Subledger Journal" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Import Excel" Selected="MenuItem_Selected" />
                    </TreeViewItem>
                    <TreeViewItem Header="Reports">
                        <TreeViewItem Header="Trial Balance" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Report Ledger" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="General Ledger" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Shares at Cost" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Share Balance" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Capital Gains" Selected="MenuItem_Selected" />
                        <TreeViewItem Header="Subledger TB" Selected="MenuItem_Selected" />
                    </TreeViewItem>
                </TreeView>
            </StackPanel>
        </Border>

        <ContentControl x:Name="ContentArea" Grid.Column="1" Background="Transparent" />
    </Grid>
</Window>
