<!-- Styles.xaml -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<!-- paste ALL your styles here -->
	<!-- SmallButtonStyle, CreditButtonStyle, DebitButtonStyle, CustomButtonStyle,
         CustomTextBoxStyle, SimpleComboBoxStyle, CustomButtonStyle2 -->


	<!-- Define styles within UserControl.Resources -->
	<Style x:Key="SmallButtonStyle" TargetType="Button">
		<Setter Property="Width" Value="30"/>
		<Setter Property="Height" Value="40"/>
		<Setter Property="Margin" Value="5"/>
		<Setter Property="Background" Value="#821131"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="BorderBrush" Value="Crimson"/>
		<Setter Property="BorderThickness" Value="2"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Border Background="{TemplateBinding Background}"
					 BorderBrush="{TemplateBinding BorderBrush}"
					 BorderThickness="{TemplateBinding BorderThickness}"
					 CornerRadius="5">
						<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<!-- Change appearance when the button is disabled -->
			<Trigger Property="IsEnabled" Value="False">
				<Setter Property="Background" Value="#A0A0A0"/>
				<Setter Property="Foreground" Value="FloralWhite"/>
				<Setter Property="BorderBrush" Value="AliceBlue"/>
			</Trigger>
			<!-- Change appearance on mouse hover -->
			<Trigger Property="IsMouseOver" Value="True">
				<Setter Property="Background" Value="#F2205B"/>
			</Trigger>
		</Style.Triggers>
	</Style>
