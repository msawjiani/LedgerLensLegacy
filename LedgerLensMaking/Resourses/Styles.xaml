	<Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
		<Setter Property="BorderBrush" Value="#2787ED"/>
		<!-- Original Value #2787ED -->
		<Setter Property="BorderThickness" Value="2"/>
		<Setter Property="Background" Value="#FFFFFF"/>
		<Setter Property="Padding" Value="0"/>
		<Setter Property="VerticalContentAlignment" Value="Center"/>
		<Setter Property="Height" Value="40"/>
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="TextBox">
					<Border CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
						<ScrollViewer x:Name="PART_ContentHost" Margin="1" Background="Transparent" />
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="SimpleComboBoxStyle" TargetType="ComboBox">
		<Setter Property="Background" Value="#FFFFFF"/>
		<Setter Property="Foreground" Value="Black"/>
		<Setter Property="BorderBrush" Value="#2787ED"/>
		<Setter Property="BorderThickness" Value="2"/>
		<Setter Property="Padding" Value="5"/>
		<Setter Property="VerticalContentAlignment" Value="Center"/>
		<Setter Property="Height" Value="40"/>
	</Style>

</ResourceDictionary>